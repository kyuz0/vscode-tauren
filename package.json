{
  "name": "tau",
  "displayName": "Tau",
  "description": "Transparent AI coding assistant with code traceability",
  "version": "1.1.0",
  "publisher": "kaiwood",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaiwood/vscode-tau.git"
  },
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "assistant",
    "chat",
    "pi",
    "tau",
    "session",
    "diff",
    "traceability"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tau.newSession",
        "title": "New Session",
        "category": "Tau"
      },
      {
        "command": "tau.resume",
        "title": "Resume Session",
        "category": "Tau"
      },
      {
        "command": "tau.fork",
        "title": "Fork Session",
        "category": "Tau"
      },
      {
        "command": "tau.clone",
        "title": "Clone Session",
        "category": "Tau"
      },
      {
        "command": "tau.showSessionTree",
        "title": "Toggle Session Tree",
        "category": "Tau"
      },
      {
        "command": "tau.toggleSessionList",
        "title": "Toggle Session List",
        "category": "Tau"
      },
      {
        "command": "tau.openSessionDiff",
        "title": "Open Session Diff",
        "category": "Tau"
      },
      {
        "command": "tau.compactSession",
        "title": "Compact Session",
        "category": "Tau"
      },
      {
        "command": "tau.exportSession",
        "title": "Export Session as HTML",
        "category": "Tau"
      },
      {
        "command": "tau.reloadPi",
        "title": "Reload Pi",
        "category": "Tau"
      },
      {
        "command": "tau.copyLastResponse",
        "title": "Copy Last Response",
        "category": "Tau"
      },
      {
        "command": "tau.openModelPicker",
        "title": "Open Model Picker",
        "category": "Tau"
      },
      {
        "command": "tau.stop",
        "title": "Stop Current Response",
        "category": "Tau"
      },
      {
        "command": "tau.toggleSteerFollowUp",
        "title": "Toggle Steer / Follow-up",
        "category": "Tau"
      },
      {
        "command": "tau.addContext",
        "title": "Add Context",
        "category": "Tau"
      },
      {
        "command": "tau.traceOrigin",
        "title": "Trace Origin",
        "category": "Tau"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tau",
          "title": "Tau",
          "icon": "resources/tau.svg"
        }
      ]
    },
    "views": {
      "tau": [
        {
          "id": "tau.chatView",
          "name": "Tau",
          "type": "webview",
          "icon": "resources/tau.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "tau.addContext",
          "when": "editorTextFocus",
          "group": "navigation@90"
        },
        {
          "command": "tau.traceOrigin",
          "when": "editorTextFocus",
          "group": "navigation@91"
        }
      ],
      "commandPalette": [
        {
          "command": "tau.showSessionTree"
        },
        {
          "command": "tau.toggleSessionList"
        }
      ],
      "view/title": [
        {
          "command": "tau.newSession",
          "when": "view == tau.chatView && !tau.busy",
          "group": "tau@1"
        },
        {
          "command": "tau.resume",
          "when": "view == tau.chatView && !tau.busy",
          "group": "tau@2"
        },
        {
          "command": "tau.openSessionDiff",
          "when": "view == tau.chatView",
          "group": "tau@3"
        },
        {
          "command": "tau.showSessionTree",
          "when": "view == tau.chatView && !tau.busy",
          "group": "tau@10"
        },
        {
          "command": "tau.openModelPicker",
          "when": "view == tau.chatView && !tau.busy",
          "group": "tau@20"
        },
        {
          "command": "tau.copyLastResponse",
          "when": "view == tau.chatView",
          "group": "tau@30"
        },
        {
          "command": "tau.toggleSteerFollowUp",
          "when": "view == tau.chatView && tau.busy",
          "group": "tau@90"
        },
        {
          "command": "tau.stop",
          "when": "view == tau.chatView && tau.busy",
          "group": "tau@91"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tau.newSession",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "tau.sidebarFocus"
      }
    ],
    "configuration": {
      "id": "tau",
      "title": "Tau",
      "type": "object",
      "properties": {
        "tau.outputColors": {
          "type": "boolean",
          "default": true,
          "description": "Enable ANSI and syntax colors in Tau output boxes. When disabled, ANSI escape sequences are stripped."
        },
        "tau.animationsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable animations in the Tau sidebar. Reduced-motion preferences still disable motion."
        },
        "tau.customUiTheme": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "modern",
            "crt",
            "amber",
            "matrix"
          ],
          "enumDescriptions": [
            "Use Tau's default custom UI styling.",
            "Use Tau's default custom UI styling inside a modern black monitor frame.",
            "Use a green phosphor CRT-style custom UI terminal.",
            "Use an amber monochrome custom UI terminal.",
            "Use a high-contrast green matrix-style custom UI terminal."
          ],
          "description": "Choose the visual theme for Pi custom UI terminal panels."
        },
        "tau.readyScript": {
          "type": "string",
          "default": "",
          "description": "Path to an executable script to run when Pi becomes ready: after starting a new Pi process without resuming a session, and after each agent run completes. Relative paths resolve from the workspace folder. Leave empty to disable."
        },
        "tau.readyScriptEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable running tau.readyScript when Pi becomes ready. Turn this off to temporarily disable the script without clearing its path."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "vscode:prepublish": "npm run compile",
    "compile": "npm run clean && npm run compile:webview && npm run compile:sdk && tsc -p ./",
    "compile:webview": "esbuild src/webview/main.ts --bundle --format=iife --target=es2022 --outfile=resources/webview/chat.js",
    "sync:vendor": "node scripts/sync-vendor-deps.js",
    "install:local": "npm run compile && npx --yes @vscode/vsce package --out tau-local.vsix && code --install-extension tau-local.vsix --force && node scripts/restart-vscode-extension-host.js",
    "test": "npm run compile -- --pretty false && vscode-test",
    "watch": "npm run compile:sdk && node scripts/watch.js",
    "compile:sdk": "node scripts/build-sdk-bundle.js"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "1.106.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "dompurify": "^3.4.2",
    "esbuild": "^0.28.0",
    "markdown-it": "^14.1.1",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "shiki": "^3.23.0",
    "vscode-shiki-bridge": "^0.5.2"
  }
}
