{
  "name": "piui",
  "displayName": "Pi UI",
  "description": "A VS Code sidebar UI for the Pi agent.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "piui.focus",
        "title": "Focus on PiUI",
        "category": "PiUI"
      },
      {
        "command": "piui.newSession",
        "title": "New Session",
        "category": "PiUI"
      }
    ],
    "keybindings": [
      {
        "command": "piui.focus",
        "key": "ctrl+[BracketLeft]",
        "mac": "cmd+[BracketLeft]"
      },
      {
        "command": "piui.newSession",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "focusedView == 'piui.chatView' || webviewId == 'piui.chatView'"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "piui",
          "title": "Pi",
          "icon": "resources/pi.svg"
        }
      ]
    },
    "views": {
      "piui": [
        {
          "id": "piui.chatView",
          "name": "Pi",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile -- --pretty false && node --test test/*.test.js",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.118.0",
    "typescript": "^6.0.3"
  }
}
