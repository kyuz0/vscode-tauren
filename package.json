{
  "name": "tauren",
  "displayName": "Tauren - Coding assistant built on top of the Pi agent",
  "description": "Transparent AI coding assistant with code traceability",
  "version": "1.6.1",
  "publisher": "kaiwood",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaiwood/vscode-tauren.git"
  },
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "coding-agent",
    "assistant",
    "chat",
    "pi",
    "pi agent",
    "tauren",
    "session",
    "diff",
    "traceability"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tauren.newSession",
        "title": "New Session",
        "category": "Tauren"
      },
      {
        "command": "tauren.resume",
        "title": "Toggle Session List",
        "category": "Tauren"
      },
      {
        "command": "tauren.fork",
        "title": "Fork Session",
        "category": "Tauren"
      },
      {
        "command": "tauren.clone",
        "title": "Clone Session",
        "category": "Tauren"
      },
      {
        "command": "tauren.showSessionTree",
        "title": "Toggle Session Tree",
        "category": "Tauren"
      },
      {
        "command": "tauren.toggleSessionList",
        "title": "Toggle Session List",
        "category": "Tauren"
      },
      {
        "command": "tauren.openSessionDiff",
        "title": "Open Session Diff",
        "category": "Tauren"
      },
      {
        "command": "tauren.renameSession",
        "title": "Rename Session",
        "category": "Tauren"
      },
      {
        "command": "tauren.compactSession",
        "title": "Compact Session",
        "category": "Tauren"
      },
      {
        "command": "tauren.exportSession",
        "title": "Export as HTML",
        "category": "Tauren"
      },
      {
        "command": "tauren.moveSessionToTrash",
        "title": "Move to Trash",
        "category": "Tauren"
      },
      {
        "command": "tauren.reloadPi",
        "title": "Reload Pi Engine",
        "category": "Tauren"
      },
      {
        "command": "tauren.copyLastResponse",
        "title": "Copy Last Response",
        "category": "Tauren"
      },
      {
        "command": "tauren.searchTranscript",
        "title": "Search in Transcript",
        "category": "Tauren"
      },
      {
        "command": "tauren.scroll",
        "title": "Scroll Active Pane",
        "category": "Tauren"
      },
      {
        "command": "tauren.scrollLineUp",
        "title": "Scroll Active Pane Up One Line",
        "category": "Tauren"
      },
      {
        "command": "tauren.scrollLineDown",
        "title": "Scroll Active Pane Down One Line",
        "category": "Tauren"
      },
      {
        "command": "tauren.openModelPicker",
        "title": "Open Model Picker",
        "category": "Tauren"
      },
      {
        "command": "tauren.raiseThinkingLevel",
        "title": "Raise Thinking Level",
        "category": "Tauren"
      },
      {
        "command": "tauren.lowerThinkingLevel",
        "title": "Lower Thinking Level",
        "category": "Tauren"
      },
      {
        "command": "tauren.toggleSettings",
        "title": "Toggle Settings",
        "category": "Tauren",
        "icon": "$(gear)"
      },
      {
        "command": "tauren.memory.status",
        "title": "Memory: Show Status",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.enable",
        "title": "Memory: Enable",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.disable",
        "title": "Memory: Disable",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.toggleAutoSummary",
        "title": "Memory: Toggle Auto Summary",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.list",
        "title": "Memory: List",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.add",
        "title": "Memory: Add Soft Memory",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.addCore",
        "title": "Memory: Add Core Memory",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.forget",
        "title": "Memory: Forget",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.promote",
        "title": "Memory: Promote",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.relax",
        "title": "Memory: Relax",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.inspect",
        "title": "Memory: Inspect",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.why",
        "title": "Memory: Explain Retrieval",
        "category": "Tauren"
      },
      {
        "command": "tauren.memory.summarize",
        "title": "Memory: Summarize Session",
        "category": "Tauren"
      },
      {
        "command": "tauren.toggleHelp",
        "title": "Toggle Help",
        "category": "Tauren",
        "icon": "$(question)"
      },
      {
        "command": "tauren.stop",
        "title": "Stop Current Response",
        "category": "Tauren"
      },
      {
        "command": "tauren.toggleSteerFollowUp",
        "title": "Toggle Steer / Follow-up",
        "category": "Tauren"
      },
      {
        "command": "tauren.addContext",
        "title": "Add Context",
        "category": "Tauren"
      },
      {
        "command": "tauren.sendSelectionToComposer",
        "title": "Send Selection to Composer",
        "category": "Tauren"
      },
      {
        "command": "tauren.traceOrigin",
        "title": "Trace Origin",
        "category": "Tauren"
      },
      {
        "command": "tauren.showDiagnostics",
        "title": "Show Diagnostics",
        "category": "Tauren"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tauren",
          "title": "Tauren",
          "icon": "resources/tauren.svg"
        }
      ]
    },
    "views": {
      "tauren": [
        {
          "id": "tauren.chatView",
          "name": "Tauren",
          "type": "webview",
          "icon": "resources/tauren.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "tauren.addContext",
          "when": "editorTextFocus",
          "group": "navigation@90"
        },
        {
          "command": "tauren.traceOrigin",
          "when": "editorTextFocus",
          "group": "navigation@91"
        }
      ],
      "commandPalette": [
        {
          "command": "tauren.memory.status",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.enable",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.disable",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.toggleAutoSummary",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.list",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.add",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.addCore",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.forget",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.promote",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.relax",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.inspect",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.why",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.memory.summarize",
          "when": "tauren.backend == kward"
        },
        {
          "command": "tauren.showSessionTree"
        },
        {
          "command": "tauren.toggleSessionList"
        },
        {
          "command": "tauren.searchTranscript"
        },
        {
          "command": "tauren.scrollLineUp",
          "when": "false"
        },
        {
          "command": "tauren.scrollLineDown",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "tauren.newSession",
          "when": "view == tauren.chatView",
          "group": "tauren@1"
        },
        {
          "command": "tauren.renameSession",
          "when": "view == tauren.chatView",
          "group": "tauren@3"
        },
        {
          "command": "tauren.compactSession",
          "when": "view == tauren.chatView && !tauren.busy",
          "group": "tauren@4"
        },
        {
          "command": "tauren.exportSession",
          "when": "view == tauren.chatView && !tauren.busy",
          "group": "tauren@5"
        },
        {
          "command": "tauren.moveSessionToTrash",
          "when": "view == tauren.chatView && !tauren.busy",
          "group": "tauren@6"
        },
        {
          "command": "tauren.toggleSettings",
          "when": "view == tauren.chatView",
          "group": "navigation@40"
        },
        {
          "command": "tauren.toggleHelp",
          "when": "view == tauren.chatView",
          "group": "navigation@50"
        },
        {
          "command": "tauren.toggleSteerFollowUp",
          "when": "view == tauren.chatView && tauren.busy",
          "group": "tauren@90"
        },
        {
          "command": "tauren.stop",
          "when": "view == tauren.chatView && tauren.busy",
          "group": "tauren@91"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tauren.newSession",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "tauren.sidebarFocus"
      },
      {
        "command": "tauren.searchTranscript",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "tauren.sidebarFocus"
      },
      {
        "command": "tauren.openModelPicker",
        "key": "ctrl+alt+.",
        "mac": "alt+cmd+.",
        "when": "tauren.sidebarFocus"
      },
      {
        "command": "tauren.scroll",
        "key": "alt+pageup",
        "mac": "cmd+pageup",
        "when": "tauren.sidebarFocus",
        "args": {
          "direction": "up",
          "amount": "page"
        }
      },
      {
        "command": "tauren.scroll",
        "key": "alt+pagedown",
        "mac": "cmd+pagedown",
        "when": "tauren.sidebarFocus",
        "args": {
          "direction": "down",
          "amount": "page"
        }
      },
      {
        "command": "tauren.scroll",
        "key": "ctrl+home",
        "mac": "cmd+up",
        "when": "tauren.sidebarFocus",
        "args": {
          "direction": "up",
          "amount": "edge"
        }
      },
      {
        "command": "tauren.scroll",
        "key": "ctrl+end",
        "mac": "cmd+down",
        "when": "tauren.sidebarFocus",
        "args": {
          "direction": "down",
          "amount": "edge"
        }
      }
    ],
    "configuration": {
      "id": "tauren",
      "title": "Tauren",
      "type": "object",
      "properties": {
        "tauren.backend": {
          "type": "string",
          "default": "pi",
          "enum": [
            "pi",
            "kward"
          ],
          "enumDescriptions": [
            "Use the bundled Pi SDK backend.",
            "Use an experimental local Kward JSON-RPC backend."
          ],
          "description": "Agent backend Tauren should use for sidebar chat. Kward is experimental."
        },
        "tauren.kward.path": {
          "type": "string",
          "default": "",
          "description": "Optional path to a Kward executable. Leave empty to launch the global `kward rpc` command when the Kward backend is selected."
        },
        "tauren.outputColors": {
          "type": "boolean",
          "default": true,
          "description": "Enable ANSI and syntax colors in Tauren output boxes. When disabled, ANSI escape sequences are stripped."
        },
        "tauren.animationsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable animations in the Tauren sidebar. Reduced-motion preferences still disable motion."
        },
        "tauren.showWelcome": {
          "type": "boolean",
          "default": true,
          "description": "Show the Welcome to Tauren empty state for new chats. Turn this back on to restore the welcome message after dismissing it."
        },
        "tauren.useTaurenShareViewer": {
          "type": "boolean",
          "default": true,
          "description": "Use Tauren docs styling for HTML exports and new /share links. When disabled, exports keep Pi styling and /share uses pi.dev unless PI_SHARE_VIEWER_URL is set."
        },
        "tauren.confirmSessionDeletion": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before moving Tauren sessions to Trash."
        },
        "tauren.debugPerformance": {
          "type": "boolean",
          "default": false,
          "description": "Collect Tauren performance diagnostics in the output channel and diagnostics view."
        },
        "tauren.customUiTheme": {
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "modern",
            "crt",
            "amber",
            "matrix"
          ],
          "enumDescriptions": [
            "Use Tauren's default custom UI styling.",
            "Use Tauren's default custom UI styling inside a modern black monitor frame.",
            "Use a green phosphor CRT-style custom UI terminal.",
            "Use an amber monochrome custom UI terminal.",
            "Use a high-contrast green matrix-style custom UI terminal."
          ],
          "description": "Choose the visual theme for Pi extension custom UI terminal panels."
        },
        "tauren.extensions.aboveWidgetsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Pi extension widgets above the Tauren composer."
        },
        "tauren.extensions.belowWidgetsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Pi extension widgets below the Tauren composer."
        },
        "tauren.extensions.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show one-line Pi extension status updates below the Tauren composer."
        },
        "tauren.extensions.backgroundColorsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Render background colors sent by Pi extension widgets."
        },
        "tauren.extensions.monospaceFontEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Use the editor monospace font for Pi extension widgets and status."
        },
        "tauren.blockHttpsImages": {
          "type": "boolean",
          "default": true,
          "description": "Block Tauren chat markdown from loading remote HTTPS images while still allowing Pi engine image data and workspace images."
        },
        "tauren.readyScript": {
          "type": "string",
          "default": "",
          "description": "Path to an executable script to run when the Pi engine becomes ready: after starting a new Pi engine process without resuming a session, and after each agent run completes. Relative paths resolve from the workspace folder. Leave empty to disable."
        },
        "tauren.readyScriptEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable running tauren.readyScript when the Pi engine becomes ready. Turn this off to temporarily disable the script without clearing its path."
        },
        "tauren.restrictFileReferencesToWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "Only open Tauren sidebar file references when they resolve inside the workspace. Turn this off to allow absolute local files outside the workspace."
        },
        "tauren.rejectEditWriteOutsideWorkspace": {
          "type": "boolean",
          "default": false,
          "description": "Reject Pi engine edit/write tool mutations outside the active workspace folder. This does not restrict bash commands."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "vscode:prepublish": "npm run compile",
    "compile": "npm run clean && npm run compile:webview && npm run compile:sdk && tsc -p ./",
    "compile:webview": "esbuild src/webview/main.ts --bundle --format=iife --target=es2022 --outfile=resources/webview/chat.js",
    "sync:vendor": "node scripts/sync-vendor-deps.js",
    "update:pi-sdk": "node scripts/update-pi-sdk.js",
    "release": "node scripts/release.js",
    "install:local": "npm run compile && npx --yes @vscode/vsce package --out tauren-local.vsix && code --install-extension tauren-local.vsix --force && node scripts/restart-vscode-extension-host.js",
    "test": "npm run compile -- --pretty false && vscode-test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "watch": "npm run compile:sdk && node scripts/watch.js",
    "compile:sdk": "node scripts/build-sdk-bundle.js"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "1.106.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "dompurify": "^3.4.2",
    "esbuild": "^0.28.0",
    "fallow": "^2.85.0",
    "markdown-it": "^14.1.1",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "shiki": "^3.23.0",
    "vscode-shiki-bridge": "^0.5.2"
  }
}
