{
  "name": "tau",
  "displayName": "Tau",
  "description": "A VS Code sidebar UI for the Pi agent.",
  "version": "0.0.1",
  "publisher": "kaiwood",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaiwood/vscode-tau.git"
  },
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tau.focus",
        "title": "Focus on Tau",
        "category": "Tau"
      },
      {
        "command": "tau.newSession",
        "title": "New Session",
        "category": "Tau"
      },
      {
        "command": "tau.resume",
        "title": "Resume Session",
        "category": "Tau"
      },
      {
        "command": "tau.fork",
        "title": "Fork Session",
        "category": "Tau"
      },
      {
        "command": "tau.clone",
        "title": "Clone Session",
        "category": "Tau"
      },
      {
        "command": "tau.addContext",
        "title": "Add Context",
        "category": "Tau"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tau",
          "title": "Tau",
          "icon": "resources/tau.svg"
        }
      ]
    },
    "views": {
      "tau": [
        {
          "id": "tau.chatView",
          "name": "Tau",
          "type": "webview",
          "icon": "resources/tau.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "tau.addContext",
          "when": "editorTextFocus",
          "group": "navigation@90"
        }
      ]
    },
    "configuration": {
      "id": "tau",
      "title": "Tau",
      "properties": {
        "tau.piPath": {
          "type": "string",
          "default": "pi",
          "description": "Command used to launch Pi. Use an executable name or path, optionally with arguments, for example: pi, /opt/homebrew/bin/pi, npx pi, or \"/path with spaces/pi\"."
        },
        "tau.outputColors": {
          "type": "boolean",
          "default": true,
          "description": "Enable ANSI and syntax colors in Tau output boxes. When disabled, ANSI escape sequences are stripped."
        },
        "tau.readyScript": {
          "type": "string",
          "default": "",
          "description": "Path to an executable script to run when Pi becomes ready: after starting a new Pi process without resuming a session, and after each agent run completes. Relative paths resolve from the workspace folder. Leave empty to disable."
        },
        "tau.readyScriptEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable running tau.readyScript when Pi becomes ready. Turn this off to temporarily disable the script without clearing its path."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "npm run clean && npm run compile:webview && tsc -p ./",
    "compile:webview": "esbuild src/webview/main.ts --bundle --format=iife --target=es2022 --outfile=resources/webview/chat.js",
    "install:local": "npm run compile && npx --yes @vscode/vsce package --out tau-local.vsix && code --install-extension tau-local.vsix --force && node scripts/restart-vscode-extension-host.js",
    "test": "npm run compile -- --pretty false && vscode-test",
    "watch": "npm run compile:webview && tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "dompurify": "^3.4.2",
    "esbuild": "^0.28.0",
    "markdown-it": "^14.1.1",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "shiki": "^3.23.0",
    "vscode-shiki-bridge": "^0.5.2"
  }
}
