{
  "name": "piui",
  "displayName": "Pi UI",
  "description": "A VS Code sidebar UI for the Pi agent.",
  "version": "0.0.1",
  "license": "MIT",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "piui.focus",
        "title": "Focus on PiUI",
        "category": "PiUI"
      },
      {
        "command": "piui.newSession",
        "title": "New Session",
        "category": "PiUI"
      }
    ],
    "keybindings": [
      {
        "command": "piui.focus",
        "key": "ctrl+[BracketLeft]",
        "mac": "cmd+[BracketLeft]"
      },
      {
        "command": "piui.newSession",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "focusedView == 'piui.chatView' || webviewId == 'piui.chatView'"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "piui",
          "title": "Pi",
          "icon": "resources/pi.svg"
        }
      ]
    },
    "views": {
      "piui": [
        {
          "id": "piui.chatView",
          "name": "Pi",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Pi UI",
      "properties": {
        "piui.fullRpcAgentCommunication": {
          "type": "boolean",
          "default": false,
          "description": "Show full RPC agent communication in the Pi sidebar transcript. When disabled, only assistant text, thinking, tool progress, and errors are shown."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile -- --pretty false && vscode-test",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "dompurify": "^3.4.2",
    "markdown-it": "^14.1.1"
  }
}
