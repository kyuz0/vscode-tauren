{
  "name": "piui",
  "displayName": "Pi UI",
  "description": "A VS Code sidebar UI for the Pi agent.",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaiwood/vscode-piui.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "piui.focus",
        "title": "Focus on PiUI",
        "category": "PiUI"
      },
      {
        "command": "piui.newSession",
        "title": "New Session",
        "category": "PiUI"
      },
      {
        "command": "piui.addContext",
        "title": "Add Context",
        "category": "PiUI"
      }
    ],
    "keybindings": [
      {
        "command": "piui.focus",
        "key": "ctrl+[BracketLeft]",
        "mac": "cmd+[BracketLeft]"
      },
      {
        "command": "piui.newSession",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "focusedView == 'piui.chatView' || webviewId == 'piui.chatView'"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "piui",
          "title": "Pi",
          "icon": "resources/pi.svg"
        }
      ]
    },
    "views": {
      "piui": [
        {
          "id": "piui.chatView",
          "name": "Pi",
          "type": "webview",
          "icon": "resources/pi.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "piui.addContext",
          "when": "editorTextFocus",
          "group": "navigation@90"
        }
      ],
      "editor/title": [
        {
          "command": "piui.addContext",
          "when": "resourceScheme == file",
          "group": "navigation@90"
        }
      ]
    },
    "configuration": {
      "title": "Pi UI",
      "properties": {
        "piui.fullRpcAgentCommunication": {
          "type": "boolean",
          "default": false,
          "description": "Show full RPC agent communication in the Pi sidebar transcript. When disabled, only assistant text, thinking, tool progress, and errors are shown."
        },
        "piui.piPath": {
          "type": "string",
          "default": "pi",
          "description": "Command used to launch Pi. Use an executable name or path, optionally with arguments, for example: pi, /opt/homebrew/bin/pi, npx pi, or \"/path with spaces/pi\"."
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run compile:webview && tsc -p ./",
    "compile:webview": "esbuild src/webview/main.ts --bundle --format=iife --target=es2022 --outfile=resources/webview/chat.js --sourcemap",
    "install:local": "npm run compile && npx --yes @vscode/vsce package --out piui-local.vsix && code --install-extension piui-local.vsix --force && node scripts/restart-vscode-extension-host.js",
    "test": "npm run compile -- --pretty false && vscode-test",
    "watch": "npm run compile:webview && tsc -watch -p ./"
  },
  "devDependencies": {
    "@highlightjs/cdn-assets": "^11.11.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "dompurify": "^3.4.2",
    "esbuild": "^0.28.0",
    "markdown-it": "^14.1.1",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3"
  }
}
